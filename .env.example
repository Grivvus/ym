# migrations
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:hackme@db:5432/postgres
GOOSE_MIGRATION_DIR=./db/migrations

# application-specific
APPLICATION_HOST=0.0.0.0
APPLICATION_PORT=8000
JWT_SECRET=secret

# database-specific
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_PASSWORD=hackme
POSTGRES_USER=postgres
POSTGRES_DB=postgres

# storage-specific
S3_ENDPOINT=storage:9000
S3_ROOT_USER=minio
S3_ROOT_PASSWORD=hackme123
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=hackme123
# optinal, default=false
S3_SECURE=false
# optional, default=""
S3_REGION=
# optional, default=""
S3_SESSION_TOKEN=

# password reset and email delivery
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_CODE_SECRET=hackme
PASSWORD_RESET_CODE_TTL=15m
PASSWORD_RESET_RESEND_COOLDOWN=1m
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_CODE_LENGTH=6
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=YM
SMTP_TLS_MODE=starttls
